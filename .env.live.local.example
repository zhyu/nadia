export NADIA_LIVE_BOT_A_TOKEN="123456:replace-with-bot-a-token"
export NADIA_LIVE_BOT_A_USERNAME="replace_with_bot_a_username"
export NADIA_LIVE_BOT_B_TOKEN="654321:replace-with-bot-b-token"
export NADIA_LIVE_BOT_B_USERNAME="replace_with_bot_b_username"

